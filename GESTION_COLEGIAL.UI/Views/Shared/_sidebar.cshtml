@{
    string pantallas = HttpContext.Current.Session["pantallas"] as string ?? "";
    var listaPantallas = pantallas.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries)
                                  .Select(p => p.Trim())
                                  .ToList();
    Func<string, bool> tiene = (nombre) => listaPantallas.Contains(nombre, StringComparer.OrdinalIgnoreCase);
}

<div class="overlay"></div>
<div class="search-overlay"></div>

