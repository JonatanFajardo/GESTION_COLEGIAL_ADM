@model GESTION_COLEGIAL.Business.Models.RolViewModel
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles{
    <link href="~/Content/css/modal-detail.css" rel="stylesheet" />
    <link href="~/Content/css/listado-catalogos.css" rel="stylesheet" />
    <link href="~/Content/css/modal-catalogos.css" rel="stylesheet" />
    <link href="~/Content/css/elements/custom-tree_view.css" rel="stylesheet" />
    <style>
        .pantallas-tree .file-tree { padding-left: 10px; }
        .pantallas-tree .file-tree li { padding: 3px 0; }
        .pantallas-tree .file-tree ul { padding-left: 25px; }
        .pantallas-tree .custom-control { display: inline-flex; align-items: center; margin-left: 4px; }
        .pantallas-tree .custom-control-label { font-weight: 400; font-size: 13px; color: #3b3f5c; cursor: pointer; }
        .pantallas-tree .grupo-header { font-weight: 600; font-size: 14px; color: #0e1726; cursor: pointer; padding: 6px 0; }
        .pantallas-tree .grupo-header:hover { color: #2196F3; }
        .pantallas-tree .grupo-content { padding-left: 15px; }
        .pantallas-tree .grupo-check-all { margin-left: 8px; font-size: 11px; color: #888ea8; cursor: pointer; }
        .pantallas-tree .grupo-check-all:hover { color: #2196F3; }
        .pantallas-tree .grupo-icon { margin-right: 6px; vertical-align: middle; }
        .pantallas-tree .pantalla-item { padding: 2px 0; }
    </style>
}

<div class="breadcrumb-wrapper-content">
    <nav class="breadcrumb-style-one" aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicio</a></li>
            <li class="breadcrumb-item active" aria-current="page">Roles</li>
        </ol>
    </nav>
</div>

<div class="page-header-catalogo">
    <div class="header-content-wrapper-catalogo">
        <div class="header-left-catalogo">
            <div class="header-icon-catalogo">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6.5 1A1.5 1.5 0 0 0 5 2.5V3H1.5A1.5 1.5 0 0 0 0 4.5v1.384l7.614 2.03a1.5 1.5 0 0 0 .772 0L16 5.884V4.5A1.5 1.5 0 0 0 14.5 3H11v-.5A1.5 1.5 0 0 0 9.5 1h-3zm0 1h3a.5.5 0 0 1 .5.5V3H6v-.5a.5.5 0 0 1 .5-.5z"/>
                    <path d="M0 12.5A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5V6.85l-7.614 2.03a2.5 2.5 0 0 1-1.272 0L0 6.85v5.65z"/>
                </svg>
            </div>
            <div class="header-text-catalogo">
                <h1>Gestion de Roles</h1>
                <p>Administre los roles y asigne pantallas de acceso</p>
            </div>
        </div>
        <div class="header-action-catalogo">
            <button class="btn-nuevo-catalogo" id="add-btn-header" data-toggle="modal" data-target="#edit-modal">
                <i class="mdi mdi-plus-circle-outline"></i>
                Nuevo Rol
            </button>
        </div>
    </div>
</div>

<div class="fluid-container">
    <div class="card-listado-catalogo">
        <div class="card-header-listado-catalogo">
            <h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm15 2h-4v3h4V4zm0 4h-4v3h4V8zm0 4h-4v3h3a1 1 0 0 0 1-1v-2zm-5 3v-3H6v3h4zm-5 0v-3H1v2a1 1 0 0 0 1 1h3zm-4-4h4V8H1v3zm0-4h4V4H1v3zm5-3v3h4V4H6zm4 4H6v3h4V8z"/>
                </svg>
                Listado de Roles
            </h3>
        </div>
        <div class="card-body-listado-catalogo">
            <div class="table-responsive">
                <table class="table table-striped table-bordered nowrap" id="datatable">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Descripcion</th>
                            <th>Pantallas</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Crear/Editar Rol -->
<div class="modal fade" id="edit-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content modal-content-catalogo">
            <div class="modal-header-catalogo">
                <div class="modal-title-wrapper-catalogo">
                    <div class="modal-icon-catalogo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M6.5 1A1.5 1.5 0 0 0 5 2.5V3H1.5A1.5 1.5 0 0 0 0 4.5v1.384l7.614 2.03a1.5 1.5 0 0 0 .772 0L16 5.884V4.5A1.5 1.5 0 0 0 14.5 3H11v-.5A1.5 1.5 0 0 0 9.5 1h-3z"/>
                            <path d="M0 12.5A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5V6.85l-7.614 2.03a2.5 2.5 0 0 1-1.272 0L0 6.85v5.65z"/>
                        </svg>
                    </div>
                    <div>
                        <h5 class="modal-title-catalogo" id="exampleModalLabel">Gestion de Rol</h5>
                        <p class="modal-subtitle-catalogo">Configure el nombre del rol</p>
                    </div>
                </div>
                <button type="button" class="close close-catalogo" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            @using (Ajax.BeginForm("CreateAsync", "Roles", new AjaxOptions
            {
                HttpMethod = "Post",
                OnBegin = "Catalogs.begin",
                OnComplete = "Catalogs.complete",
                OnFailure = "Catalogs.failure",
                OnSuccess = "Catalogs.success"
            }))
            {
            <div class="fluid-container">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @Html.HiddenFor(model => model.Rol_Id, new { @id = "item-id" })
                <div class="modal-body-catalogo">
                    <div class="section-header-catalogo">
                        <span>Informacion del Rol</span>
                    </div>
                    <div class="form-card-catalogo">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group-catalogo">
                                    <label class="form-label-catalogo">
                                        Descripcion del Rol
                                        <span class="required-asterisk-catalogo">*</span>
                                    </label>
                                    @Html.EditorFor(model => model.Rol_Descripcion, new { htmlAttributes = new { @class = "form-control form-input-catalogo", placeholder = "Ej: Administrador, Docente..." } })
                                    @Html.ValidationMessageFor(model => model.Rol_Descripcion, "", new { @class = "text-danger validation-message-catalogo" })
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group-catalogo">
                                    <label class="form-label-catalogo">Estado</label>
                                    <div style="margin-top: 8px;">
                                        @Html.CheckBoxFor(model => model.Rol_Estado, new { @id = "Rol_Estado" })
                                        <label for="Rol_Estado">Activo</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer-catalogo">
                    <button type="button" class="btn-cancel-catalogo" data-dismiss="modal">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                        </svg>
                        Cancelar
                    </button>
                    <button type="submit" class="btn-save-catalogo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/>
                        </svg>
                        Guardar Rol
                    </button>
                </div>
            </div>
            }
        </div>
    </div>
</div>

<!-- Modal Delete -->
<div class="modal fade" id="delete-modal" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 440px;">
        @using (Ajax.BeginForm("DeleteAsync", "Roles", new AjaxOptions
        {
            HttpMethod = "Post",
            OnBegin = "Catalogs.begin",
            OnComplete = "Catalogs.complete",
            OnFailure = "Catalogs.failure",
            OnSuccess = "Catalogs.success"
        }))
        {
        <div class="modal-content" style="border-radius: 12px; border: none;">
            <div class="modal-header" style="border-bottom: none; padding: 20px 24px 0;">
                <button type="button" class="close" data-dismiss="modal" style="padding: 0; margin: 0; opacity: 0.5;"><span>&times;</span></button>
            </div>
            <div class="modal-body text-center" style="padding: 0 40px 32px;">
                @Html.HiddenFor(model => model.Rol_Id, new { @id = "delete-item-id" })
                <div class="d-flex justify-content-center mb-3">
                    <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <div style="width: 56px; height: 56px; background-color: #dc2626; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-exclamation-triangle" style="color: white; font-size: 28px;"></i>
                        </div>
                    </div>
                </div>
                <h5 class="mb-3" style="color: #1f2937; font-weight: 600;">Eliminar rol</h5>
                <p class="mb-4" style="color: #6b7280; font-size: 14px;">Esta seguro de que desea eliminar el rol <span id="delete-item-name" style="font-weight: 600;"></span>?</p>
            </div>
            <div class="modal-footer" style="border-top: none; padding: 0 40px 32px; gap: 12px;">
                <button type="button" class="btn" data-dismiss="modal" style="flex: 1; padding: 10px 24px; border-radius: 8px; background-color: #f3f4f6; border: 1px solid #d1d5db; color: #374151 !important;">Cancelar</button>
                <button type="submit" class="btn btn-danger" style="flex: 1; padding: 10px 24px; border-radius: 8px; background-color: #dc2626; border: none;">Eliminar</button>
            </div>
        </div>
        }
    </div>
</div>

<!-- Modal Detalle -->
<div class="modal fade" id="detail-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-file-alt"></i> Detalle del Rol</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="info-card">
                    <div class="info-grid">
                        <div><label class="info-label">ID</label><p class="info-value" id="detail-rol-id"></p></div>
                        <div><label class="info-label">Descripcion</label><p class="info-value" id="detail-rol-descripcion"></p></div>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-grid">
                        <div><label class="info-label">Estado</label><p class="info-value" id="detail-rol-estado"></p></div>
                        <div><label class="info-label">Pantallas asignadas</label><p class="info-value" id="detail-rol-cantidadpantallas"></p></div>
                    </div>
                </div>
                <div class="audit-section">
                    <h6 class="audit-section-title"><i class="fas fa-history"></i> Auditoria</h6>
                    <div class="audit-card">
                        <div class="audit-icon green"><i class="fas fa-calendar"></i></div>
                        <div class="audit-info">
                            <div><label class="audit-label">Fecha de creacion</label><p class="audit-value" id="detail-rol-fecharegistra"></p></div>
                        </div>
                    </div>
                    <div class="audit-card">
                        <div class="audit-icon blue"><i class="fas fa-calendar"></i></div>
                        <div class="audit-info">
                            <div><label class="audit-label">Fecha de modificacion</label><p class="audit-value" id="detail-rol-fechamodifica"></p></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="mdi mdi-close mr-1"></i>Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Asignar Pantallas (Tree View) -->
<div class="modal fade" id="pantallas-modal" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content modal-content-catalogo">
            <div class="modal-header-catalogo">
                <div class="modal-title-wrapper-catalogo">
                    <div class="modal-icon-catalogo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M5.338 1.59a61.44 61.44 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.725 10.725 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a.55.55 0 0 0 .101.025.615.615 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.726 10.726 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.775 11.775 0 0 1-2.517 2.453 7.159 7.159 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7.158 7.158 0 0 1-1.048-.625 11.777 11.777 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 62.456 62.456 0 0 1 5.072.56z"/>
                            <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0z"/>
                        </svg>
                    </div>
                    <div>
                        <h5 class="modal-title-catalogo">Asignar Pantallas al Rol</h5>
                        <p class="modal-subtitle-catalogo">Seleccione las pantallas y acciones permitidas para este rol</p>
                    </div>
                </div>
                <button type="button" class="close close-catalogo" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body-catalogo">
                <input type="hidden" id="pantallas-rol-id" />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-primary mr-2" id="btn-select-all">
                            <i class="fas fa-check-double mr-1"></i>Seleccionar todas
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="btn-deselect-all">
                            <i class="fas fa-times mr-1"></i>Deseleccionar todas
                        </button>
                    </div>
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-info" id="btn-expand-all">
                            <i class="fas fa-expand-arrows-alt mr-1"></i>Expandir
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-info" id="btn-collapse-all">
                            <i class="fas fa-compress-arrows-alt mr-1"></i>Colapsar
                        </button>
                    </div>
                </div>
                <div id="pantallas-tree-container" class="pantallas-tree" style="max-height: 450px; overflow-y: auto; border: 1px solid #e0e6ed; border-radius: 8px; padding: 15px;">
                    <!-- Tree se carga dinamicamente -->
                </div>
            </div>
            <div class="modal-footer-catalogo">
                <button type="button" class="btn-cancel-catalogo" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-save-catalogo" id="btn-save-pantallas">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/>
                    </svg>
                    Guardar Pantallas
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/Content/plugins/treeview/custom-jstree.js"></script>
    <script src="~/Content/js/pages/roles.js"></script>
    <script>
        // Inicializar DataTable de roles (con boton de pantallas integrado)
        Roles.datatableCatalogs({
            urlList: "@Url.Action("ListAsync")",
            urlDetail: "@Url.Action("DetailAsync")"
        });

        // Configurar el patron de catalogos para crear/editar
        Catalogs.configure({
            displayName: "roles",
            urlUpdate: "@Url.Action("FindAsync")"
        });

        // Configurar el patron de detalle en modal
        CatalogsCfg.configure({
            displayName: "rol",
            getUrl: "@Url.Action("DetailAsync")"
        });
    </script>
    <script>
        // === Logica de asignacion de pantallas con Tree View ===
        var urlPantallasList = "@Url.Action("PantallasListAsync")";
        var urlPantallasByRol = "@Url.Action("PantallasByRolAsync")";
        var urlSavePantallas = "@Url.Action("SavePantallasAsync")";

        // Abrir modal de pantallas
        $(document).on('click', '.btn-pantallas', function () {
            var rolId = $(this).data('id');
            $('#pantallas-rol-id').val(rolId);
            loadPantallasTree(rolId);
            $('#pantallas-modal').modal('show');
        });

        function loadPantallasTree(rolId) {
            var container = $('#pantallas-tree-container');
            container.html('<div class="text-center py-4"><i class="fa-solid fa-spinner fa-spin-pulse fa-2x" style="color: #F7A400;"></i><p class="mt-2 text-muted">Cargando pantallas...</p></div>');

            // Cargar todas las pantallas
            $.ajax({
                url: urlPantallasList,
                type: "GET",
                dataType: "json",
                success: function (allPantallas) {
                    // Cargar pantallas asignadas
                    $.ajax({
                        url: urlPantallasByRol + "?id=" + rolId,
                        type: "GET",
                        dataType: "json",
                        success: function (assigned) {
                            var assignedIds = [];
                            if (assigned && assigned.data) {
                                assignedIds = assigned.data.map(function (x) { return x.Pan_Id; });
                            }
                            var pantallas = allPantallas.data || allPantallas;
                            buildTree(container, pantallas, assignedIds);
                        },
                        error: function () {
                            container.html('<p class="text-danger text-center py-3">Error al cargar pantallas asignadas</p>');
                        }
                    });
                },
                error: function () {
                    container.html('<p class="text-danger text-center py-3">Error al cargar pantallas</p>');
                }
            });
        }

        function buildTree(container, pantallas, assignedIds) {
            if (!pantallas || pantallas.length === 0) {
                container.html('<p class="text-muted text-center py-3">No hay pantallas disponibles</p>');
                return;
            }

            // Agrupar por Pan_Grupo
            var grupos = {};
            $.each(pantallas, function (i, p) {
                var grupo = p.Pan_Grupo || 'General';
                if (!grupos[grupo]) grupos[grupo] = [];
                grupos[grupo].push(p);
            });

            // Iconos por grupo
            var grupoIcons = {
                'General': 'fas fa-home',
                'Cursos': 'fas fa-book-open',
                'Alumnos': 'fas fa-user-graduate',
                'Recursos Humanos': 'fas fa-briefcase',
                'Horarios': 'fas fa-calendar-alt',
                'Institucion': 'fas fa-university',
                'Financiero': 'fas fa-dollar-sign',
                'Seguridad': 'fas fa-shield-alt',
                'Academico': 'fas fa-graduation-cap'
            };

            var html = '<ul class="file-tree">';

            $.each(grupos, function (grupoName, items) {
                var grupoId = grupoName.replace(/\s+/g, '_').toLowerCase();
                var icon = grupoIcons[grupoName] || 'fas fa-folder';
                var totalItems = items.length;
                var checkedItems = 0;
                $.each(items, function (i, p) {
                    if (assignedIds.indexOf(p.Pan_Id) >= 0) checkedItems++;
                });

                html += '<li class="file-tree-folder open">';
                html += '<span class="grupo-header" data-grupo="' + grupoId + '">';
                html += '<i class="' + icon + ' grupo-icon" style="color: #2196F3;"></i>';
                html += grupoName;
                html += ' <span class="badge badge-secondary" style="font-size: 11px;">' + checkedItems + '/' + totalItems + '</span>';
                html += '<span class="grupo-check-all" data-grupo="' + grupoId + '" title="Seleccionar/Deseleccionar grupo"> (marcar todo)</span>';
                html += '</span>';
                html += '<ul style="display: block;">';

                $.each(items, function (i, p) {
                    var checked = assignedIds.indexOf(p.Pan_Id) >= 0 ? 'checked' : '';
                    html += '<li class="pantalla-item">';
                    html += '<div class="custom-control custom-checkbox">';
                    html += '<input type="checkbox" class="custom-control-input pantalla-check" id="pan_' + p.Pan_Id + '" value="' + p.Pan_Id + '" data-grupo="' + grupoId + '" ' + checked + '>';
                    html += '<label class="custom-control-label" for="pan_' + p.Pan_Id + '">' + p.Pan_Descripcion + '</label>';
                    html += '</div>';
                    html += '</li>';
                });

                html += '</ul>';
                html += '</li>';
            });

            html += '</ul>';
            container.html(html);

            // Inicializar eventos del tree
            initTreeEvents();
        }

        function initTreeEvents() {
            // Toggle grupo (expandir/colapsar)
            $('.grupo-header').off('click').on('click', function (e) {
                if ($(e.target).hasClass('grupo-check-all')) return; // No colapsar al click en "marcar todo"
                var $ul = $(this).closest('li').children('ul');
                $ul.slideToggle(200);
                $(this).closest('li').toggleClass('open');
            });

            // Marcar/desmarcar todo el grupo
            $('.grupo-check-all').off('click').on('click', function (e) {
                e.stopPropagation();
                var grupoId = $(this).data('grupo');
                var $checks = $('.pantalla-check[data-grupo="' + grupoId + '"]');
                var allChecked = $checks.length === $checks.filter(':checked').length;
                $checks.prop('checked', !allChecked);
                updateGrupoBadge(grupoId);
            });

            // Actualizar badge al cambiar checkbox
            $('.pantalla-check').off('change').on('change', function () {
                var grupoId = $(this).data('grupo');
                updateGrupoBadge(grupoId);
            });
        }

        function updateGrupoBadge(grupoId) {
            var $checks = $('.pantalla-check[data-grupo="' + grupoId + '"]');
            var total = $checks.length;
            var checked = $checks.filter(':checked').length;
            var $header = $('.grupo-header[data-grupo="' + grupoId + '"]');
            $header.find('.badge').text(checked + '/' + total);
        }

        // Seleccionar / Deseleccionar todas
        $('#btn-select-all').click(function () {
            $('.pantalla-check').prop('checked', true);
            // Actualizar todos los badges
            $('.grupo-header').each(function () {
                updateGrupoBadge($(this).data('grupo'));
            });
        });

        $('#btn-deselect-all').click(function () {
            $('.pantalla-check').prop('checked', false);
            $('.grupo-header').each(function () {
                updateGrupoBadge($(this).data('grupo'));
            });
        });

        // Expandir / Colapsar todos
        $('#btn-expand-all').click(function () {
            $('.file-tree-folder').addClass('open').children('ul').slideDown(200);
        });

        $('#btn-collapse-all').click(function () {
            $('.file-tree-folder').removeClass('open').children('ul').slideUp(200);
        });

        // Guardar pantallas
        $('#btn-save-pantallas').click(function () {
            var rolId = $('#pantallas-rol-id').val();
            var selectedIds = [];
            $('.pantalla-check:checked').each(function () {
                selectedIds.push($(this).val());
            });

            var $btn = $(this);
            $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Guardando...');

            $.ajax({
                url: urlSavePantallas,
                type: "POST",
                data: { rolId: rolId, pantallaIds: selectedIds.join(',') },
                success: function (response) {
                    $('#pantallas-modal').modal('hide');
                    alertConfig.alert(response.message, response.type);
                    var table = Roles.getTable();
                    if (table) {
                        table.ajax.reload(null, false);
                    } else {
                        location.reload();
                    }
                },
                error: function () {
                    alertConfig.alert("Error al guardar las pantallas", "error");
                },
                complete: function () {
                    $btn.prop('disabled', false).html('<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/></svg> Guardar Pantallas');
                }
            });
        });
    </script>
}
