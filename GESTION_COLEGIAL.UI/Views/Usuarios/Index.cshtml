@model GESTION_COLEGIAL.Business.Models.UsuarioViewModel
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles{
    <link href="~/Content/css/modal-detail.css" rel="stylesheet" />
    <link href="~/Content/css/listado-catalogos.css" rel="stylesheet" />
    <link href="~/Content/css/modal-catalogos.css" rel="stylesheet" />
}


<div class="breadcrumb-wrapper-content ">
    <nav class="breadcrumb-style-one" aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicio</a></li>
            <li class="breadcrumb-item active" aria-current="page">Usuarios</li>
        </ol>
    </nav>
</div>

<div class="page-header-catalogo">
    <div class="header-content-wrapper-catalogo">
        <div class="header-left-catalogo">
            <div class="header-icon-catalogo">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                </svg>
            </div>
            <div class="header-text-catalogo">
                <h1>Gestion de Usuarios</h1>
                <p>Administre los usuarios y sus roles de acceso al sistema</p>
            </div>
        </div>
        <div class="header-action-catalogo">
            <button class="btn-nuevo-catalogo" id="add-btn-header" data-toggle="modal" data-target="#edit-modal">
                <i class="mdi mdi-plus-circle-outline"></i>
                Nuevo Usuario
            </button>
        </div>
    </div>
</div>

<div class="fluid-container">
    @* Listado *@
    <div class="card-listado-catalogo">
        <div class="card-header-listado-catalogo">
            <h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm15 2h-4v3h4V4zm0 4h-4v3h4V8zm0 4h-4v3h3a1 1 0 0 0 1-1v-2zm-5 3v-3H6v3h4zm-5 0v-3H1v2a1 1 0 0 0 1 1h3zm-4-4h4V8H1v3zm0-4h4V4H1v3zm5-3v3h4V4H6zm4 4H6v3h4V8z"/>
                </svg>
                Listado de Usuarios
            </h3>
        </div>
        <div class="card-body-listado-catalogo">
            <div class="table-responsive">
                <table class="table table-striped table-bordered nowrap" id="datatable">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Usuario</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="edit-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content modal-content-catalogo">
            <!-- Header with Orange Gradient -->
            <div class="modal-header-catalogo">
                <div class="modal-title-wrapper-catalogo">
                    <div class="modal-icon-catalogo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        </svg>
                    </div>
                    <div>
                        <h5 class="modal-title-catalogo" id="exampleModalLabel">Gestion de Usuario</h5>
                        <p class="modal-subtitle-catalogo">Configure los datos del usuario del sistema</p>
                    </div>
                </div>
                <button type="button" class="close close-catalogo" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            @using (Ajax.BeginForm("CreateAsync", "Usuarios", new AjaxOptions
            {
                HttpMethod = "Post",
                OnBegin = "Catalogs.begin",
                OnComplete = "Catalogs.complete",
                OnFailure = "Catalogs.failure",
                OnSuccess = "Catalogs.success"

            }))
            {
            <div class="fluid-container">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                @Html.HiddenFor(model => model.Usu_Id, new { @id = "item-id" })
                <div class="modal-body-catalogo">
                    <!-- Informacion Basica -->
                    <div class="section-header-catalogo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5v-7zm1.294 7.456A1.999 1.999 0 0 1 4.732 11h5.536a2.01 2.01 0 0 1 .732-.732V3.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v7a.5.5 0 0 0 .294.456zM12 10a2 2 0 0 1 1.732 1h.768a.5.5 0 0 0 .5-.5V8.35a.5.5 0 0 0-.11-.312l-1.48-1.85A.5.5 0 0 0 13.02 6H12v4zm-9 1a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm9 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                        </svg>
                        <span>Informacion del Usuario</span>
                    </div>

                    <div class="form-card-catalogo">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-catalogo">
                                    <label class="form-label-catalogo">
                                        Nombre de Usuario
                                        <span class="required-asterisk-catalogo">*</span>
                                    </label>
                                    @Html.EditorFor(model => model.Usu_Name, new { htmlAttributes = new { @class = "form-control form-input-catalogo", placeholder = "Ej: jsmith" } })
                                    @Html.ValidationMessageFor(model => model.Usu_Name, "", new { @class = "text-danger validation-message-catalogo" })
                                    <small class="form-text-hint-catalogo">
                                        Ingrese un nombre de usuario unico para el sistema
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-catalogo">
                                    <label class="form-label-catalogo">
                                        Rol
                                        <span class="required-asterisk-catalogo">*</span>
                                    </label>
                                    @Html.DropDownListFor(model => model.Rol_Id, new SelectList(Enumerable.Empty<SelectListItem>()), "Seleccione un rol", new { @class = "form-control form-input-catalogo", @id = "Rol_Id" })
                                    @Html.ValidationMessageFor(model => model.Rol_Id, "", new { @class = "text-danger validation-message-catalogo" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-catalogo">
                                    <label class="form-label-catalogo">
                                        Empleado Id
                                    </label>
                                    @Html.EditorFor(model => model.Emp_Id, new { htmlAttributes = new { @class = "form-control form-input-catalogo", placeholder = "Id del empleado" } })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-catalogo">
                                    <label class="form-label-catalogo">
                                        Estado
                                    </label>
                                    <div style="margin-top: 8px;">
                                        @Html.CheckBoxFor(model => model.Usu_EsActivo, new { @id = "Usu_EsActivo" })
                                        <label for="Usu_EsActivo">Usuario activo</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer-catalogo">
                    <button type="button" class="btn-cancel-catalogo" data-dismiss="modal">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                        </svg>
                        Cancelar
                    </button>
                    <button type="submit" class="btn-save-catalogo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/>
                        </svg>
                        Guardar Usuario
                    </button>
                </div>
            </div>
            }
        </div>
    </div>
</div>
<!-- Fin Modal -->
<!-- Modal Delete-->
<div class="modal fade" id="delete-modal" tabindex="-1" role="dialog" data-backdrop="static" aria-labelledby="deleteModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 440px;">
        @using (Ajax.BeginForm("DeleteAsync", "Usuarios", new AjaxOptions
        {
            HttpMethod = "Post",
            OnBegin = "Catalogs.begin",
            OnComplete = "Catalogs.complete",
            OnFailure = "Catalogs.failure",
            OnSuccess = "Catalogs.success"
        }))
        {
        <div class="modal-content" style="border-radius: 12px; border: none;">
            <div class="modal-header" style="border-bottom: none; padding: 20px 24px 0;">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="padding: 0; margin: 0; opacity: 0.5;">
                    <span aria-hidden="true" style="font-size: 24px;">&times;</span>
                </button>
            </div>

            <div class="modal-body text-center" style="padding: 0 40px 32px;">
                @Html.HiddenFor(model => model.Usu_Id, new { @id = "delete-item-id" })

                <div class="d-flex justify-content-center mb-3">
                    <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <div style="width: 56px; height: 56px; background-color: #dc2626; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-exclamation-triangle" style="color: white; font-size: 28px;"></i>
                        </div>
                    </div>
                </div>

                <h5 class="mb-3" style="color: #1f2937; font-weight: 600; font-size: 20px;">Eliminar usuario</h5>

                <p class="mb-4" style="color: #6b7280; font-size: 14px; line-height: 1.5;">
                    Esta seguro de que desea eliminar el usuario <span id="delete-item-name" style="font-weight: 600;"></span>?
                </p>

                <div class="alert d-flex align-items-start text-left" style="background-color: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 16px; margin-bottom: 0;">
                    <div style="flex-shrink: 0; margin-right: 12px;">
                        <i class="fas fa-exclamation-triangle" style="color: #dc2626; font-size: 18px;"></i>
                    </div>
                    <div style="flex: 1;">
                        <p class="mb-1" style="color: #991b1b; font-weight: 600; font-size: 13px; margin: 0;">Esta accion no se puede deshacer</p>
                        <p class="mb-0" style="color: #991b1b; font-size: 13px; margin: 0;">El registro sera eliminado permanentemente del sistema.</p>
                    </div>
                </div>
            </div>

            <div class="modal-footer" style="border-top: none; padding: 0 40px 32px; gap: 12px;">
                <button type="button" class="btn" data-dismiss="modal" style="flex: 1; padding: 10px 24px; border-radius: 8px; font-weight: 500; background-color: #f3f4f6; border: 1px solid #d1d5db; color: #374151 !important; font-size: 14px;">
                    Cancelar
                </button>
                <button type="submit" class="btn btn-danger" style="flex: 1; padding: 10px 24px; border-radius: 8px; font-weight: 500; background-color: #dc2626; border: none; font-size: 14px;">
                    Eliminar
                </button>
            </div>
        </div>
        }
    </div>
</div>
<!-- Fin Modal -->

    <!-- Modal Detalle -->
    <div class="modal fade" id="detail-modal" tabindex="-1" role="dialog" aria-labelledby="detailModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="detailModalLabel">
                        <i class="fas fa-file-alt"></i>
                        Detalle del Usuario
                    </h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="info-card">
                        <div class="info-grid">
                            <div>
                                <label class="info-label">ID</label>
                                <p class="info-value" id="detail-usu-id"></p>
                            </div>
                            <div>
                                <label class="info-label">Nombre de Usuario</label>
                                <p class="info-value" id="detail-usu-name"></p>
                            </div>
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-grid">
                            <div>
                                <label class="info-label">Rol</label>
                                <p class="info-value" id="detail-rol-descripcion"></p>
                            </div>
                            <div>
                                <label class="info-label">Estado</label>
                                <p class="info-value" id="detail-usu-esactivo"></p>
                            </div>
                        </div>
                    </div>

                    <div class="audit-section">
                        <h6 class="audit-section-title">
                            <i class="fas fa-history"></i>
                            Informacion de Auditoria
                        </h6>

                        <div class="audit-card">
                            <div class="audit-icon green">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="audit-info">
                                <div>
                                    <label class="audit-label">
                                        <i class="fas fa-calendar icon-small"></i>
                                        Fecha de creacion
                                    </label>
                                    <p class="audit-value" id="detail-usu-fechacreacion"></p>
                                </div>
                            </div>
                        </div>

                        <div class="audit-card">
                            <div class="audit-icon blue">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="audit-info">
                                <div>
                                    <label class="audit-label">
                                        <i class="fas fa-calendar icon-small"></i>
                                        Fecha de modificacion
                                    </label>
                                    <p class="audit-value" id="detail-usu-fechamodificacion"></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        <i class="mdi mdi-close mr-1"></i>Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- Fin Modal Detalle -->

@section Scripts{
    <script src="~/Content/js/pages/usuarios.js"></script>
    <script>
        Usuarios.datatableCatalogs({
            urlList: "@Url.Action("ListAsync")",
            urlDetail: "@Url.Action("DetailAsync")"
        });
    </script>
    <script>
        Catalogs.configure({
            displayName: "usuarios",
            urlUpdate: "@Url.Action("FindAsync")"
        });
        CatalogsCfg.configure({
            displayName: "usuario",
            getUrl: "@Url.Action("DetailAsync")"
        });
    </script>
    <script>
        // Cargar roles en el dropdown al abrir el modal
        $('#edit-modal').on('show.bs.modal', function () {
            $.ajax({
                url: "@Url.Action("RolesDropdownAsync")",
                type: "GET",
                dataType: "json",
                success: function (data) {
                    var dropdown = $('#Rol_Id');
                    var currentVal = dropdown.val();
                    dropdown.find('option:not(:first)').remove();
                    if (data && data.data) {
                        $.each(data.data, function (i, item) {
                            dropdown.append($('<option></option>').val(item.Rol_Id).text(item.Rol_Descripcion));
                        });
                    }
                    if (currentVal) {
                        dropdown.val(currentVal);
                    }
                }
            });
        });
    </script>
}
