@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Acceso Denegado";
}

<div class="row layout-top-spacing justify-content-center">
    <div class="col-lg-6 col-md-8 col-sm-10">
        <div class="text-center mt-5">
            <div class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </div>
            <h2 class="text-danger mb-3">Acceso Denegado</h2>
            <p class="text-muted mb-4" style="font-size: 1.1rem;">
                No tiene permisos para acceder a esta sección.
                Contacte al administrador si necesita acceso.
            </p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                <i class="fas fa-home mr-2"></i> Volver al Inicio
            </a>
        </div>
    </div>
</div>
